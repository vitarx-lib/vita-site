{
  "name": "@vitapress/plugin-search",
  "version": "0.0.0",
  "description": "Local search plugin for VitaPress",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm test && tsc -p tsconfig.build.json && pnpm check:circular",
    "check:circular": "madge --extensions js --circular dist --warning --exclude '.*\\.d\\.ts$'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release": "pnpm dlx @vitarx/release-cli"
  },
  "license": "MIT",
  "peerDependencies": {
    "vitapress": "^1.0.0",
    "vitarx": "^4.0.0-0",
    "vitarx-router": "^4.0.0-0"
  },
  "devDependencies": {
    "vitapress": "workspace:*"
  }
}

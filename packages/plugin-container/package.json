{
  "name": "@vitapress/plugin-search",
  "version": "0.0.0",
  "description": "Local search plugin for VitaPress",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm test && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release": "pnpm dlx @vitarx/release-cli"
  },
  "license": "MIT",
  "peerDependencies": {
    "markdown-it-container": "^4.0.0",
    "vitapress": "^1.0.0-0"
  },
  "devDependencies": {
    "@types/markdown-it-container": "^4.0.0",
    "markdown-it": "^14.1.1",
    "@types/markdown-it": "^14.1.1",
    "markdown-it-container": "^4.0.0",
    "vitapress": "workspace:*"
  }
}

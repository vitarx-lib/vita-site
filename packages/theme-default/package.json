{
  "name": "@vitapress/theme-default",
  "version": "0.0.0",
  "description": "default theme plugin for VitaPress",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm test && tsc -p tsconfig.build.json && pnpm check:circular && cp -r src/assets ./dist/",
    "check:circular": "madge --extensions js --circular dist --warning --exclude '.*\\.d\\.ts$'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release": "pnpm dlx @vitarx/release-cli"
  },
  "license": "MIT",
  "peerDependencies": {
    "vitapress": "^1.0.0-0"
  },
  "dependencies": {
    "@vitapress/plugin-container": "workspace:^",
    "@vitapress/plugin-search": "workspace:^",
    "@zmaui/color": "^1.0.0-alpha.5"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.1",
    "markdown-it": "^14.1.1",
    "sass-embedded": "1.70.0",
    "vitapress": "workspace:*"
  }
}

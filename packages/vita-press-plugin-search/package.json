{
  "name": "vita-press-plugin-search",
  "version": "0.0.0",
  "description": "Local search plugin for VitaPress",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm test && tsc -p tsconfig.build.json",

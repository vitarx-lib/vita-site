    "test": "vitest run",
    "release": "pnpm dlx @vitarx/release-cli"
  },
  "license": "MIT",
  "peerDependencies": {
    "vitapress": "^1.0.0",
    "vitarx": "^4.0.0-0",
    "vitarx-router": "^4.0.0-0"
  },
  "devDependencies": {
    "vitapress": "workspace:*",
    "vitarx": "4.0.0-beta.14",
    "vitarx-router": "^4.0.0-beta.16",
    "@vitarx/plugin-vite": "^0.0.1-beta.8"
  }
}
